---
const {
  src,
  name,
  fit = "Contain",
  alignment = "center",
  autoplay = true,
  stateMachines = "",
} = Astro.props;
---

<rive-canvas>
  <canvas
    width="320"
    height="320"
    data-src={src}
    data-fit={fit}
    data-alignment={alignment}
    data-autoplay={autoplay}
    data-statemachines={stateMachines}></canvas>
</rive-canvas>

<script src="./Rive.client.js"></script>
